<%- include('../partials/header.ejs') %>

<!-- Reset Password Section -->
<section class="ff-login-section">
    <div class="login-container">

        <!-- Header -->
        <div class="login-header">
            <h1 class="login-title">Reset Password</h1>
            <p class="login-subtitle">Enter your new password below</p>
        </div>

        <!-- Reset Password Form -->
        <form action="/freeze-feast/change-password/<%= token %>" method="POST" class="login-form">

            <!-- New Password -->
            <div class="form-floating-group">
                <label for="newPassword">New Password</label>
                <input 
                    type="password" 
                    id="newPassword" 
                    name="newPassword" 
                    placeholder="Enter new password" 
                    required
                >
            </div>

            <!-- Confirm Password -->
            <div class="form-floating-group">
                <label for="confirmPassword">Confirm Password</label>
                <input 
                    type="password" 
                    id="confirmPassword" 
                    name="confirmPassword" 
                    placeholder="Confirm password" 
                    required
                >
            </div>

            <!-- Submit Button -->
            <button type="submit" class="btn-login">Reset Password</button>

        </form>

        <!-- Back to Login -->
        <div class="create-account">
            <p>Remember your password? <a href="/freeze-feast/login">Back to Login</a></p>
        </div>
    </div>
</section>

<%- include('../partials/footer.ejs') %>