<%- include('../partials/header.ejs') %>

 <!-- Login Section -->
    <section class="ff-login-section">
        <div class="login-container">

            <!-- Header -->
            <div class="login-header">
                <h1 class="login-title">Welcome Back</h1>
                <p class="login-subtitle">Enter your credential to continue</p>
            </div>

            <!-- Login Form -->
            <form action="/freeze-feast/login" method="post"  class="login-form" id="loginForm">
                <!-- Email Field -->
                <div class="form-floating-group">
                    <label for="email">Email Address</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        placeholder="example@gmail.com" 
                        required
                        autocomplete="email"
                    >
                </div>

                <!-- Password Field -->
                <div class="form-floating-group password-group">
                    <label for="password">Password</label>
                    <input 
                        type="password" 
                        id="password" 
                        name="password" 
                        placeholder="8+ characters" 
                        required
                        autocomplete="current-password"
                    >
                    <button type="button" class="password-toggle" id="togglePassword">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>

                <!-- Forgot Password -->
                <div class="forgot-password">
                    <a href="forgot.html">Forgot password?</a>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn-login">Sign In</button>
            </form>

            <!-- Create Account -->
            <div class="create-account">
                <p>Don't have account? <a href="/freeze-feast/register">Create Account</a></p>
            </div>
        </div>
    </section>

<%- include('../partials/footer.ejs') %>