<%- include('../partials/header.ejs') %>

<% if (error.length > 0) { %>
  <div class="alert alert-danger">
    <%= error[0] %>
  </div>
<% } %>

<% if (success.length > 0) { %>
  <div class="alert alert-success">
    <%= success[0] %>
  </div>
<% } %>

    <!-- Contact Section -->
    <section class="ff-contact-section">
        <div class="container">
            <div class="ff-contact-wrapper">

                <!-- Contact Form -->
                <div class="ff-contact-form-wrapper">
                    <span class="ff-contact-subtitle">Get In Touch</span>
                    <h2 class="ff-contact-title">Send Us a Message</h2>
                    <p class="ff-contact-desc">Have a question, special request, or want to book a table? We'd love to hear from you!</p>

                    <form action="/freeze-feast/contact" method="POST">
                         <!-- <form action="/freeze-feast/contact" method="POST"> -->

                        <div class="ff-form-row">
                            <div class="ff-form-group">
                                <input type="text" name="name" placeholder="Your Name" required>
                            </div>

                            <div class="ff-form-group">
                                <input type="email" name="email" placeholder="Your Email" required>
                            </div>
                        </div>
                        <div class="ff-form-row">
                            <div class="ff-form-group">
                                <input type="tel" name="phone_number" placeholder="Phone Number" required>
                            </div>
                            <div class="ff-form-group">
                                <input type="text" name="subject" placeholder="Subject" required>
                            </div>
                        </div>

                        <div class="ff-form-group">
                            <textarea placeholder="Your Message" name="description" required></textarea>
                        </div>
                        
                        <button type="submit"  class="ff-btn-submit">
                            Send Message
                            <i class="fa-solid fa-paper-plane"></i>
                        </button>

                    </form>
                </div>
                <!-- Office Cards -->
                <div class="ff-offices-wrapper">

                    <img src="../../../../assets/images/contact.png" >
                    
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Info Section -->
    <section class="ff-contact-info-section">
        <div class="container">
            <div class="ff-info-grid">
                <!-- Phone -->
                <div class="ff-info-card">
                    <div class="ff-info-icon">
                        <i class="fa-solid fa-phone"></i>
                    </div>
                    <h4>Phone Number</h4>
                    <p><a href="tel:+18006565222">1800 6565 222</a></p>
                    <p><a href="tel:+18006565333">1800 6565 333</a></p>
                </div>

                <!-- Email -->
                <div class="ff-info-card">
                    <div class="ff-info-icon">
                        <i class="fa-solid fa-envelope"></i>
                    </div>
                    <h4>Email Address</h4>
                    <p><a href="mailto:info@freezefeast.com">info@freezefeast.com</a></p>
                    <p><a href="mailto:support@freezefeast.com">support@freezefeast.com</a></p>
                </div>

                <!-- Location -->
                <div class="ff-info-card">
                    <div class="ff-info-icon">
                        <i class="fa-solid fa-location-dot"></i>
                    </div>
                    <h4>Our Location</h4>
                    <p>1487 Rocky Horse Carrer<br>Arlington, TX 16819</p>
                </div>

                <!-- Hours -->
                <div class="ff-info-card">
                    <div class="ff-info-icon">
                        <i class="fa-regular fa-clock"></i>
                    </div>
                    <h4>Opening Hours</h4>
                    <p>Mon-Fri: 9 AM – 10 PM<br>Sat-Sun: 10 AM – 11 PM</p>
                </div>
            </div>
        </div>
    </section>

<%- include('../partials/footer.ejs') %>